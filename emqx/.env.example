# Pin the image to a stable tag instead of using "latest".
EMQX_IMAGE_TAG=6.2.0

# Dashboard login:
# username is always "admin"
# choose a strong password before first start
EMQX_DASHBOARD_PASSWORD=ChangeMeNow_UseALongRandomPassword

# Keep MQTT listeners private during bootstrap.
# After authentication/authorization is configured,
# change EMQX_BIND_8883 to 0.0.0.0 and then open 8883 in Tencent Cloud.
EMQX_BIND_1883=127.0.0.1
EMQX_BIND_8883=127.0.0.1
EMQX_BIND_18083=127.0.0.1
